# Canvas LMS Configuration
# Per-user web UI uses CANVAS_INSTITUTION_URL (Northeastern) + token from the browser session.
CANVAS_INSTITUTION_URL=https://northeastern.instructure.com
CANVAS_API_URL=https://northeastern.instructure.com
CANVAS_API_TOKEN=""
# Set to "false" on servers to use direct Canvas REST calls and avoid browser OAuth for Canvas MCP.
CANVAS_USE_MCP="true"

# GitHub Configuration
GITHUB_TOKEN=""
GITHUB_USERNAME=""
GITHUB_ORG=  # Optional: Organization name if you want to create repos in an org

# Notion Configuration (required for writing assignments)
# Create an internal integration in Notion and share your parent page with it.
NOTION_TOKEN=""
NOTION_PARENT_PAGE_ID=""  # Parent page ID where assignment pages will be created

# Canvas MCP Server (via Smithery CLI)
# Get your key at https://smithery.ai/account/api-keys
# The Smithery CLI must be logged in: npx -y @smithery/cli login
SMITHERY_API_KEY=""

# Frontend Origins for FastAPI CORS (comma-separated)
# Example: FRONTEND_ORIGINS=https://app.example.com,https://www.example.com
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Per-user sessions (web UI): Fernet key from:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# When set, users must POST /auth/session (see UI); MCP/CLI still use CANVAS_API_TOKEN / GITHUB_TOKEN above.
CREDENTIAL_ENCRYPTION_KEY=
# Optional: set SESSION_COOKIE_SECURE=true behind HTTPS
SESSION_COOKIE_SECURE=